# Server
PORT=5000

# Database (MongoDB Atlas or local)
MONGODB_URI=mongodb://localhost:27017/ticket_management

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — frontend origin. Single value, or comma-separated for multiple
# (e.g. https://your-app.vercel.app,http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Seed accounts (used by `npm run seed`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
# Optional overrides for the demo Agent/User accounts (defaults shown):
# AGENT_EMAIL=agent@example.com
# AGENT_PASSWORD=Agent@123
# USER_EMAIL=user@example.com
# USER_PASSWORD=User@123
